<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Home</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(to right, #fbc2eb, #a6c1ee);
        color: #333;
    }
    header {
        background-color: #ff7f50;
        color: white;
        padding: 20px;
        text-align: center;
        font-size: 24px;
        font-weight: bold;
    }
    nav {
        display: flex;
        justify-content: center;
        margin: 20px 0;
    }
    nav a {
        text-decoration: none;
        color: white;
        background-color: #ff6347;
        padding: 10px 20px;
        border-radius: 8px;
        margin: 0 10px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
        font-size: 16px;
    }
    nav a:hover {
        background-color: #ff4500;
    }

    /* Post creation section */
    .post-creator {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: 20px auto;
        width: 90%;
        max-width: 600px;
    }
    .post-creator textarea {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        border: 2px solid #ddd;
        resize: none;
        font-size: 16px;
    }
    .post-creator button {
        margin-top: 10px;
        padding: 12px 20px;
        background-color: #ff7f50;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
    }
    .post-creator button:hover {
        background-color: #ff4500;
    }

    /* Posts container */
    #postsContainer {
        margin: 20px auto;
        width: 90%;
        max-width: 600px;
    }
    .post-card {
        background-color: white;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 15px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
</style>
</head>
<body>

<header>Welcome to the Home Page</header>

<nav>
    <a href="home.html"><i class="fas fa-house"></i> Home</a>
    <a href="profile.html"><i class="fas fa-user"></i> Profile</a>
    <a href="login.html"><i class="fas fa-power-off"></i> Logout</a>
</nav>

<div class="post-creator">
    <textarea id="postContent" placeholder="Write something..."></textarea>
    <button onclick="createPost()"><i class="fas fa-pencil-alt"></i> Post</button>
</div>

<div id="postsContainer"></div>

<script>
    const posts = []; // Empty array, no dummy posts

    function displayPosts() {
        const container = document.getElementById('postsContainer');
        container.innerHTML = '';
        posts.slice().reverse().forEach(post => {
            const postDiv = document.createElement('div');
            postDiv.className = 'post-card';
            postDiv.textContent = post;
            container.appendChild(postDiv);
        });
    }

    function createPost() {
        const content = document.getElementById('postContent').value.trim();
        if(content === '') return alert('Please write something!');
        posts.push(content); // Add only your post
        document.getElementById('postContent').value = '';
        displayPosts();
    }
</script>

</body>
</html>
